{
  "name": "nba-guessing-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "refresh:data": "tsx scripts/refresh-player-data.ts auto",
    "refresh:data:current": "tsx scripts/refresh-player-data.ts current",
    "refresh:data:history": "tsx scripts/refresh-player-data.ts history",
    "refresh:data:all": "tsx scripts/refresh-player-data.ts all",
    "refresh:data:images": "tsx scripts/refresh-player-data.ts images",
    "refresh:data:repair-missing": "tsx scripts/refresh-player-data.ts repair-missing",
    "refresh:data:add-missing": "tsx scripts/refresh-player-data.ts add-missing",
    "enrich:full": "tsx scripts/enrich/run-full.ts",
    "enrich:repair": "tsx scripts/enrich/run-repair.ts",
    "enrich:repair:missing": "tsx scripts/enrich/run-repair-missing.ts",
    "enrich:repair:playwright": "tsx scripts/enrich/run-repair-playwright.ts",
    "enrich:report": "tsx scripts/enrich/report.ts",
    "test": "vitest run --config vitest.config.mjs --configLoader native --pool threads",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "scrapfly-sdk": "^0.10.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "crawlee": "^3.16.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
